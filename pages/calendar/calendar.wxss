/* 全局页面容器 - 匹配浅黄色背景 */
.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 20rpx);
  padding-bottom: 120rpx;
}

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--yh-surface, #fff);
  padding: 22rpx 28rpx;
  margin: 0 24rpx 24rpx;
  border-radius: var(--yh-radius-lg, 28rpx);
  border: 1rpx solid var(--yh-border, #dde3eb);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 24rpx rgba(40, 48, 56, 0.045));
}

.back-btn, .help-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.help-button {
  width: 60rpx;
  height: 60rpx;
  background-color: #4a7eb8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.3);
}

.back-icon, .help-icon {
  font-size: 32rpx;
  color: #333333;
}

.help-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

/* 小睡记录控制区 */
.sleep-control {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 睡眠状态显示 */
.sleep-status {
  margin-bottom: 30rpx;
}

.status-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

/* 正在小睡状态 */
.napping-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  width: 100%;
}

.timer-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.timer-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.timer-value {
  font-size: 64rpx;
  color: #4a7eb8;
  font-weight: bold;
  font-family: 'Courier New', monospace;
  letter-spacing: 4rpx;
}

.start-time {
  font-size: 26rpx;
  color: #999999;
}

/* 睡眠按钮 */
.sleep-btn {
  width: 280rpx;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 45rpx;
  border: none;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.sleep-btn::after {
  border: none;
}

.sleep-btn:active {
  transform: scale(0.96);
}

/* 开始小睡按钮 */
.start-btn {
  background: var(--yh-primary, #587838);
  color: #FFFFFF;
}

.start-btn .btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.start-btn .btn-text {
  font-size: 32rpx;
}

/* 结束小睡按钮 */
.end-btn {
  /* 跳色：结束动作用主黄 */
  background: var(--yh-sage, #E8B848);
  color: #FFFFFF;
}

.end-btn .btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.end-btn .btn-text {
  font-size: 32rpx;
}

.sleep-tip {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
  line-height: 1.4;
}

/* 星期栏 */
.week-bar {
  display: flex;
  background-color: var(--yh-bg, #eceff4);
  padding: 15rpx 0;
  margin-bottom: 10rpx;
}

.week-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
}

/* 日历列表 */
.calendar-list {
  padding: 0 20rpx;
}

/* 月份容器 */
.calendar-month {
  margin-bottom: 30rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
}

.month-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 20rpx;
  text-align: center;
  background-color: var(--yh-bg, #eceff4);
  padding: 10rpx;
  border-radius: 8rpx;
}

/* 日期网格 */
.date-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.date-item {
  width: 100%;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #333333;
  border-radius: 8rpx;
  background-color: #F5F5F5;
}

.date-item.active {
  background-color: #4a7eb8;
  color: #FFFFFF;
}

.date-item.checked-in {
  background-color: #52C41A;
  color: #FFFFFF;
}

.date-item.today {
  border: 2rpx solid #4a7eb8;
}
