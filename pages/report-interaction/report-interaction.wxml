<view class="page-container" style="--nav-bar-height: {{navBarTotalHeight}}rpx;">
  <view wx:if="{{loading}}" class="loading-panel">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在生成反馈报告...</text>
  </view>

  <block wx:else>
    <view class="back-button" bindtap="goBack">
      <view class="back-icon-wrapper">
        <text class="back-arrow">‹</text>
      </view>
      <text class="back-text">返回</text>
    </view>

    <view class="hero-card">
      <text class="hero-tag">亲子互动反馈</text>
      <text class="hero-title">高质量互动越稳定，越能支持孩子理解和表达语言</text>
      <text class="hero-desc">以下结果基于本次问卷作答情况生成，可作为家庭日常互动优化的参考。</text>
    </view>

    <view class="summary-card">
      <view class="summary-left">
        <text class="summary-label">总分</text>
        <view class="score-row">
          <text class="score-number">{{totalScore}}</text>
          <text class="score-max">/ {{maxScore}}</text>
        </view>
        <view class="level-chip" style="color: {{scoreLevelColor}}; background: {{scoreLevelTone}};">
          {{scoreLevel}}
        </view>
        <text class="score-percent">完成度 {{percent}}%</text>
      </view>

      <view class="summary-right">
        <view class="summary-info-item">
          <text class="summary-info-label">宝宝</text>
          <text class="summary-info-value">{{babyInfo.name}}</text>
        </view>
        <view class="summary-info-item">
          <text class="summary-info-label">月龄</text>
          <text class="summary-info-value">{{babyInfo.age}}</text>
        </view>
        <view class="summary-info-item">
          <text class="summary-info-label">测评日期</text>
          <text class="summary-info-value">{{babyInfo.testTime}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <text class="card-title">雷达图概览</text>
        <text class="card-subtitle">核心维度一眼查看</text>
      </view>
      <canvas canvas-id="radarCanvas" class="radar-canvas"></canvas>

      <view class="legend-list">
        <view class="legend-item" wx:for="{{dimensionScores}}" wx:key="dimension">
          <view class="legend-dot" style="background: {{item.levelColor}};"></view>
          <text class="legend-text">{{item.dimension}} {{item.score}} / {{item.maxScore}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <text class="card-title">维度明细</text>
        <text class="card-subtitle">分数越高，代表该维度表现越稳定</text>
      </view>

      <view class="dimension-list">
        <view class="dimension-item" wx:for="{{dimensionScores}}" wx:key="dimension">
          <view class="dimension-top">
            <text class="dimension-name">{{item.dimension}}</text>
            <text class="dimension-score">{{item.score}} / {{item.maxScore}}</text>
          </view>
          <view class="dimension-bar">
            <view class="dimension-fill" style="width: {{item.percent}}%; background: {{item.levelColor}};"></view>
          </view>
          <view class="dimension-bottom">
            <text class="dimension-percent">{{item.percent}}%</text>
            <view class="mini-chip" style="color: {{item.levelColor}}; background: {{item.levelTone}};">{{item.level}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="card ai-card">
      <view class="card-header">
        <view class="ai-badge">AI智能分析</view>
      </view>
      <view class="analysis-list">
        <view class="analysis-item" wx:for="{{analysisParagraphs}}" wx:key="index">
          <text class="analysis-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-header">
        <text class="card-title">行动建议</text>
        <text class="card-subtitle">优先从最低维度开始调整，效果更明显</text>
      </view>

      <view class="suggestion-list">
        <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="index">
          <view class="suggestion-index">{{index + 1}}</view>
          <text class="suggestion-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="action-row">
      <button class="ghost-btn" bindtap="goBack">返回</button>
      <button class="primary-btn" bindtap="goToTest">重新测评</button>
    </view>

    <view class="bottom-space"></view>
  </block>
</view>
