<view class="page-container" style="--nav-bar-height: {{navBarTotalHeight}}rpx;">

<view class="top-nav">
  <view class="back-btn" bindtap="goBack">
    <text class="back-icon">←</text>
  </view>
  <view class="nav-title">搜索文章</view>
  <view class="placeholder"></view>
</view>

<view class="search-bar">
  <input
    class="search-input"
    placeholder="请输入标题或关键词"
    value="{{keyword}}"
    bindinput="onInput"
    confirm-type="search"
    bindconfirm="onSearch"
  />
  <view class="search-btn" bindtap="onSearch">搜索</view>
</view>

<view wx:if="{{resultList.length === 0}}" class="empty-tip">
  未找到相关内容
</view>

<view wx:for="{{resultList}}" wx:key="id" class="article-card" data-id="{{item.id}}" bindtap="goToDetail">
  <image class="article-cover" src="{{item.cover}}" mode="aspectFill"></image>
  <view class="article-info">
    <view class="article-title">{{item.title}}</view>
    <view class="article-author">{{item.author}}</view>
  </view>
</view>

</view>
