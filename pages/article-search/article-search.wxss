.page-container {
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0 30rpx 40rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 20rpx);
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.back-btn,
.placeholder {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32rpx;
  color: #333;
}

.nav-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  color: #333333;
}

.search-btn {
  background: #4a7eb8;
  color: #FFFFFF;
  border-radius: 999rpx;
  padding: 18rpx 28rpx;
  font-size: 26rpx;
  text-align: center;
}

.article-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.article-cover {
  width: 100%;
  height: 220rpx;
  background: #F3F3F3;
}

.article-info {
  padding: 20rpx;
}

.article-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.article-author {
  font-size: 24rpx;
  color: #999999;
}

.empty-tip {
  text-align: center;
  margin-top: 120rpx;
  color: #999999;
  font-size: 28rpx;
}
