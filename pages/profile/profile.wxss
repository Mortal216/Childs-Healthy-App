/* 我的 — 与全局设计令牌一致 */
.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 12rpx);
  padding-bottom: 32rpx;
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--yh-surface, #fff);
  padding: 24rpx 32rpx;
  margin: 0 24rpx 24rpx;
  border-radius: var(--yh-radius-lg, 28rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.nav-title {
  font-size: 34rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
}

.setting-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yh-surface-muted, #f7f9fc);
  border-radius: 50%;
  border: 1rpx solid var(--yh-border, #e4e9f0);
}

.setting-icon {
  font-size: 30rpx;
}

.login-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
}

.login-card {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  padding: 56rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin: 0 24rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-card, 0 8rpx 32rpx rgba(42, 49, 56, 0.07));
}

.login-avatar {
  width: 120rpx;
  height: 120rpx;
  background: var(--yh-primary-soft, #e8f0f8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  border: 3rpx solid var(--yh-primary-faint, #d4e4f2);
}

.login-avatar .avatar-placeholder {
  font-size: 56rpx;
}

.login-title {
  font-size: 36rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: var(--yh-text-muted, #8b939e);
  margin-bottom: 40rpx;
}

.login-btn {
  background: var(--yh-primary, #587838);
  color: #ffffff;
  border: none;
  border-radius: var(--yh-radius-pill, 999rpx);
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  width: 100%;
  box-shadow: 0 8rpx 24rpx rgba(74, 126, 184, 0.28);
}

.login-btn::after {
  border: none;
}

.user-card {
  display: flex;
  align-items: center;
  background-color: var(--yh-surface, #fff);
  padding: 28rpx 32rpx;
  margin: 0 24rpx 20rpx;
  border-radius: var(--yh-radius-lg, 28rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  background: var(--yh-primary-soft, #e8f0f8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 2rpx solid var(--yh-primary-faint, #d4e4f2);
}

.avatar-placeholder {
  font-size: 40rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.username {
  font-size: 30rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
}

.uid {
  font-size: 24rpx;
  color: var(--yh-text-muted, #8b939e);
}

.arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 26rpx;
  color: var(--yh-text-muted, #8b939e);
}

.stats-bar {
  display: flex;
  align-items: center;
  /* 黄色加深：提示条用主黄 */
  background-color: var(--yh-sage, #E8B848);
  padding: 22rpx 28rpx;
  margin: 0 24rpx 20rpx;
  border-radius: var(--yh-radius-md, 20rpx);
  border: 1rpx solid var(--ref-yellow-500, #E0B848);
}

.stats-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.stats-text {
  font-size: 26rpx;
  color: #FFFFFF;
  line-height: 1.5;
}

.menu-list {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  margin: 0 24rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  overflow: hidden;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--yh-divider, #eef1f6);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--yh-surface-muted, #f7f9fc);
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  width: 44rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 500;
}

.sleep-dashboard {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.dashboard-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.dashboard-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
}

.dashboard-more {
  display: flex;
  align-items: center;
}

.more-text {
  font-size: 24rpx;
  color: var(--yh-text-secondary, #5c6570);
  margin-right: 5rpx;
}

.more-icon {
  font-size: 20rpx;
  color: var(--yh-text-muted, #8b939e);
}

.sleep-chart {
  margin-top: 10rpx;
}

.chart-title {
  font-size: 24rpx;
  color: var(--yh-text-muted, #8b939e);
  margin-bottom: 20rpx;
  text-align: center;
}

.chart-container {
  height: 200rpx;
  position: relative;
}

.chart-grid {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.chart-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.chart-label {
  flex: 1;
  text-align: center;
  font-size: 20rpx;
  color: var(--yh-text-muted, #8b939e);
}

.chart-bars {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 10rpx;
}

.chart-bar-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.chart-bar {
  width: 100%;
  /* 跳色：图表柱用主黄 */
  background: var(--yh-sage, #E8B848);
  border-radius: 6rpx 6rpx 0 0;
  transition: height 0.3s ease;
}

.chart-value {
  font-size: 18rpx;
  color: var(--yh-text-secondary, #5c6570);
  margin-top: 6rpx;
}

.form-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(42, 49, 56, 0.45);
}

.form-container {
  position: relative;
  width: 88%;
  max-height: 82vh;
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  display: flex;
  flex-direction: column;
  z-index: 1001;
  overflow: hidden;
  box-shadow: var(--yh-shadow-card, 0 8rpx 32rpx rgba(42, 49, 56, 0.12));
}

.form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--yh-divider, #eef1f6);
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
}

.form-close {
  font-size: 40rpx;
  color: var(--yh-text-muted, #8b939e);
  padding: 0 10rpx;
}

.form-content {
  padding: 28rpx 32rpx;
  max-height: 58vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--yh-text, #2a3138);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  border-radius: var(--yh-radius-md, 20rpx);
  font-size: 28rpx;
  box-sizing: border-box;
  background: var(--yh-surface-muted, #f7f9fc);
}

.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-item {
  padding: 16rpx 36rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  border-radius: var(--yh-radius-pill, 999rpx);
  font-size: 28rpx;
  color: var(--yh-text-secondary, #5c6570);
  background-color: var(--yh-surface, #fff);
}

.radio-item.active {
  border-color: var(--yh-primary, #4a7eb8);
  background-color: var(--yh-primary-soft, #e8f0f8);
  color: var(--yh-primary-pressed, #3d6a9c);
  font-weight: 600;
}

.date-picker-group {
  display: flex;
  gap: 12rpx;
}

.date-picker-group picker {
  flex: 1;
}

.picker-item {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  border-radius: var(--yh-radius-md, 20rpx);
  font-size: 26rpx;
  color: var(--yh-text, #2a3138);
  background-color: var(--yh-surface-muted, #f7f9fc);
}

.age-display {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--yh-primary, #4a7eb8);
  text-align: center;
  font-weight: 500;
}

.form-footer {
  display: flex;
  padding: 20rpx 32rpx 32rpx;
  gap: 20rpx;
  border-top: 1rpx solid var(--yh-divider, #eef1f6);
}

.form-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--yh-radius-pill, 999rpx);
  font-size: 30rpx;
  border: none;
}

.form-btn::after {
  border: none;
}

.form-btn.cancel {
  background-color: var(--yh-surface-muted, #f7f9fc);
  color: var(--yh-text-secondary, #5c6570);
  border: 1rpx solid var(--yh-border, #e4e9f0);
}

.form-btn.save {
  background: var(--yh-primary, #587838);
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(74, 126, 184, 0.25);
}
