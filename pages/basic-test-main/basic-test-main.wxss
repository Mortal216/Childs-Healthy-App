/* 全局页面容器（动态顶部内边距避开导航栏） */
.page-container {
  width: 100%;
  min-height: 100vh;
  background: #F7F8FA;
  padding: 0 30rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 40rpx);
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* 返回按钮样式 - 统一美观设计 */
.back-button {
  position: absolute;
  top: calc(var(--nav-bar-height) + 20rpx);
  left: 30rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  transition: all 0.3s ease;
  border: 2rpx solid #9EBEED;
}

.back-button:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.back-icon-wrapper {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #4E90F5;
  border-radius: 50%;
}

.back-arrow {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  color: #4B6B03;
  font-weight: 500;
}

/* 页面标题样式 */
.page-title {
  align-self: center;
  margin-bottom: 20rpx;
  margin-top: 80rpx;
  width: 100%;
  max-width: 680rpx;
  text-align: left;
}

.page-title .yh-h1 { margin-bottom: 12rpx; }
.page-title .yh-lead { margin-bottom: 0; }

/* 测试卡片样式 */
.test-card {
  border-radius: 32rpx; /* 约等于 16px */
  border: 2rpx solid #9EBEED;
  padding: 40rpx; /* 约等于 20px */
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: transform 150ms ease;
}

.test-card:active {
  transform: scale(0.99);
}

.test-kicker {
  margin-bottom: -8rpx;
}

.test-title {
  font-size: 36rpx;
  color: #4B6B03;
  font-weight: 600;
  line-height: 1.3;
}

.start-btn {
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  border-radius: 48rpx; /* 约等于 24px */
  font-weight: 600;
}

.start-btn::after {
  border: none;
}

.start-btn:active {
  transform: scale(0.98);
}

.test-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
