<!-- 页面容器 -->
<view class="page-container">
  <!-- 标题 -->
  <view class="title">重置密码</view>

  <!-- 手机号输入框 -->
  <view class="input-item">
    <input 
      class="input" 
      placeholder="请输入手机号" 
      bindinput="onPhoneInput" 
      value="{{phone}}"
      type="number"
    />
  </view>

  <!-- 验证码输入框（带获取按钮） -->
  <view class="input-item">
    <input 
      class="input" 
      placeholder="请输入验证码" 
      bindinput="onCodeInput" 
      value="{{code}}"
      type="number"
    />
    <button 
      class="code-btn" 
      bindtap="getCode" 
      disabled="{{codeDisabled}}"
    >
      {{codeText}}
    </button>
  </view>

  <!-- 新密码输入框 -->
  <view class="input-item">
    <input 
      class="input" 
      placeholder="请输入新密码" 
      password="{{true}}" 
      bindinput="onNewPwdInput" 
      value="{{newPwd}}"
    />
  </view>

  <!-- 确定按钮 -->
  <button class="reset-btn" bindtap="resetPwd">确定</button>

  <!-- 返回登录链接 -->
  <view class="login-link" bindtap="goToLogin">
    <text class="link-text">返回登录</text>
  </view>

  <!-- 底部标语 -->
  <view class="footer-text">科学评估·个性化干预</view>
</view>