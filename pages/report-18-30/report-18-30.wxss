/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding-top: calc(var(--nav-bar-height) + 20rpx);
  padding-bottom: 40rpx;
}

/* 顶部导航栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--yh-surface, #F0F0E0);
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yh-surface-muted, #F8F8F0);
  border-radius: 50%;
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.back-icon {
  font-size: 32rpx;
  color: var(--yh-text, #506840);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--yh-text, #506840);
}

.share-btn {
  padding: 10rpx 20rpx;
  background: var(--yh-primary, #587838);
  border-radius: 30rpx;
}

.share-icon {
  font-size: 24rpx;
  color: #fff;
}

/* 加载状态 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--yh-border, #E0E0E0);
  border-top-color: var(--yh-primary, #587838);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--yh-text-muted, #88A870);
}

/* 报告内容 */
.report-content {
  padding: 0 30rpx;
}

/* 宝宝信息卡片 */
.baby-info-card {
  display: flex;
  align-items: center;
  background: var(--yh-surface, #F0F0E0);
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.baby-avatar {
  width: 100rpx;
  height: 100rpx;
  background: var(--yh-primary-soft, #88A870);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.avatar-text {
  font-size: 48rpx;
}

.baby-details {
  flex: 1;
}

.baby-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--yh-text, #506840);
  display: block;
  margin-bottom: 8rpx;
}

.baby-age {
  font-size: 28rpx;
  color: var(--yh-text-secondary, #5C6F53);
  display: block;
  margin-bottom: 4rpx;
}

.test-time {
  font-size: 24rpx;
  color: var(--yh-text-muted, #88A870);
}

/* 综合评分卡片 */
.score-card {
  background: var(--yh-primary, #587838);
  padding: 40rpx;
  border-radius: 24rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 40rpx rgba(88, 120, 56, 0.22);
}

.score-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.score-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.score-level-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.score-level-tag.excellent {
  background: var(--yh-accent-purple, #C8C8E8);
  color: #fff;
}

.score-level-tag.good {
  background: var(--yh-primary-soft, #B8D078);
  color: #fff;
}

.score-level-tag.average {
  background: var(--yh-sage, #E8B848);
  color: #fff;
}

.score-level-tag.attention {
  background: var(--yh-primary-pressed, #506840);
  color: #fff;
}

.score-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 30rpx;
}

.score-number {
  font-size: 80rpx;
  font-weight: 700;
  color: #fff;
}

.score-total {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 10rpx;
}

.score-progress {
  margin-top: 20rpx;
}

.progress-bar {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

/* 各维度得分 */
.dimensions-section {
  background: var(--yh-surface, #F0F0E0);
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--yh-text, #506840);
  display: block;
  margin-bottom: 30rpx;
}

.dimensions-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.dimension-item {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--yh-border, #E0E0E0);
}

.dimension-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.dim-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.dim-name {
  font-size: 28rpx;
  color: var(--yh-text, #506840);
  font-weight: 500;
}

.dim-level {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

.dim-level.excellent {
  background: var(--yh-accent-purple, #C8C8E8);
  color: #FFFFFF;
}

.dim-level.good {
  background: var(--yh-primary-soft, #B8D078);
  color: #FFFFFF;
}

.dim-level.average {
  background: var(--yh-sage, #E8B848);
  color: #FFFFFF;
}

.dim-level.attention {
  background: var(--yh-primary-pressed, #506840);
  color: #FFFFFF;
}

.dim-score {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--yh-primary, #587838);
}

.score-unit {
  font-size: 24rpx;
  color: var(--yh-text-muted, #88A870);
  margin-left: 4rpx;
}

.dim-progress {
  margin-top: 8rpx;
}

.progress-bg {
  height: 12rpx;
  background: var(--yh-surface-muted, #F8F8F0);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill-bar {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-fill-bar.excellent {
  background: var(--yh-primary, #587838);
}

.progress-fill-bar.good {
  background: var(--yh-primary, #587838);
}

.progress-fill-bar.average {
  background: var(--yh-sage, #E8B848);
}

.progress-fill-bar.attention {
  background: var(--yh-primary-pressed, #506840);
}

/* 个性化干预建议 */
.suggestions-section {
  background: var(--yh-surface, #F0F0E0);
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.suggestions-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  background: var(--yh-surface-muted, #F8F8F0);
  padding: 24rpx;
  border-radius: 16rpx;
  border-left: 6rpx solid var(--yh-sage, #E8B848);
}

.suggestion-icon {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 32rpx;
}

.suggestion-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--yh-text, #506840);
  line-height: 1.6;
}

/* 底部按钮 */
.bottom-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 20rpx 0 40rpx;
}

.action-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  text-align: center;
}

.action-btn.primary {
  background: var(--yh-primary, #587838);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(88, 120, 56, 0.22);
}

.action-btn.secondary {
  background: var(--yh-surface, #F0F0E0);
  color: var(--yh-text-secondary, #5C6F53);
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.action-btn::after {
  border: none;
}
