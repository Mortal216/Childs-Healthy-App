<!-- 页面容器（绑定动态导航栏高度） -->
<view class="page-container" style="--nav-bar-height: {{navBarTotalHeight}}rpx;">
  <!-- 返回按钮 -->
  <view class="back-button" bindtap="goBack">
    <text class="back-icon">←</text>
    <text class="back-text">返回</text>
  </view>
  
  <!-- 页面标题 -->
  <view class="page-title">
    <text>智能任务推送</text>
    <text class="page-subtitle">基于测评结果和时间段的个性化建议</text>
  </view>
  
  <view class="current-info">
    <view class="info-item">
      <text class="info-label">当前时间：</text>
      <text class="info-value">{{currentTime}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">当前时段：</text>
      <text class="info-value time-slot">{{timeSlot}}</text>
    </view>
  </view>
  
  <view class="tasks-section">
    <text class="section-title">推荐任务</text>
    
    <block wx:if="{{tasks.length > 0}}">
      <view class="task-list">
        <view wx:for="{{tasks}}" wx:key="index" class="task-item">
          <view class="task-header">
            <text class="task-title">{{item.title}}</text>
            <view class="task-badge"></view>
          </view>
          <text class="task-description">{{item.description}}</text>
        </view>
      </view>
    </block>
    
    <block wx:else>
      <view class="empty-state">
        <text class="empty-text">正在生成任务...</text>
      </view>
    </block>
  </view>
  
  <view class="refresh-section">
    <button bindtap="refreshTasks" class="refresh-btn" loading="{{loading}}">
      {{loading ? '刷新中...' : '刷新任务'}}
    </button>
  </view>
</view>