.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0 32rpx 40rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 40rpx);
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.back-button {
  position: absolute;
  top: calc(var(--nav-bar-height) + 16rpx);
  left: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  z-index: 100;
  background: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-pill, 999rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.back-icon {
  font-size: 28rpx;
  color: var(--yh-primary, #4a7eb8);
}

.back-text {
  font-size: 26rpx;
  color: var(--yh-text-secondary, #5c6570);
}

.page-title {
  align-self: center;
  margin-bottom: 8rpx;
  margin-top: 56rpx;
  text-align: center;
  padding: 0 24rpx;
}

.page-title text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: var(--yh-text-secondary, #5c6570);
  font-weight: normal !important;
  line-height: 1.5;
}

.current-info {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
  padding: 28rpx 32rpx;
  margin-bottom: 8rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: var(--yh-text-secondary, #5c6570);
}

.info-value {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--yh-text, #2a3138);
}

.time-slot {
  color: var(--yh-primary, #4a7eb8);
  font-weight: 600;
}

.tasks-section {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
  padding: 28rpx 32rpx;
  margin-bottom: 8rpx;
  flex: 1;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
  margin-bottom: 24rpx;
  display: block;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-item {
  background-color: var(--yh-surface-muted, #f7f9fc);
  border-radius: var(--yh-radius-md, 20rpx);
  padding: 28rpx 24rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  /* 跳色增强：左侧强调线使用主黄 */
  border-left: 6rpx solid var(--yh-sage, #E8B848);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.task-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
  flex: 1;
}

.task-badge {
  width: 14rpx;
  height: 14rpx;
  /* 跳色增强：小徽标用浅紫 */
  background-color: var(--yh-accent-purple, #C8C8E8);
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.task-description {
  font-size: 26rpx;
  color: var(--yh-text-secondary, #5c6570);
  line-height: 1.55;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: var(--yh-text-muted, #8b939e);
}

.empty-text {
  font-size: 26rpx;
}

.refresh-section {
  display: flex;
  justify-content: center;
  margin-top: 12rpx;
  margin-bottom: 32rpx;
}

.refresh-btn {
  /* 跳色：刷新/再试用主黄 */
  background: var(--yh-sage, #E8B848);
  color: #ffffff;
  border: none;
  border-radius: var(--yh-radius-pill, 999rpx);
  padding: 24rpx 72rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(74, 126, 184, 0.28);
}

.refresh-btn::after {
  border: none;
}

.refresh-btn:active {
  opacity: 0.92;
}
