.page-container {
  width: 100%;
  height: 100vh;
  background-color: #eef1e3;
  padding: 0 24rpx 24rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 16rpx);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.top-bar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 6rpx;
}

.top-left,
.top-right {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: #f4f6ea;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-icon {
  font-size: 34rpx;
  color: #6b7b52;
}

.help-icon {
  font-size: 32rpx;
  color: #6b7b52;
}

.top-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #6b7b52;
  letter-spacing: 2rpx;
}

.content-scroll {
  flex: 1;
  height: 100%;
}

.hero {
  position: relative;
  width: 100%;
  min-height: 86vh;
  border-radius: 28rpx;
  overflow: hidden;
  background: #e7eadc;
}

.hero-bg {
  width: 100%;
  display: block;
  /* widthFix 下高度自适应，保持完整显示 */
}

.mic-wrapper {
  position: absolute;
  left: 50%;
  bottom: 10%;
  transform: translateX(-50%);
  z-index: 10;
}

.mic-btn {
  width: 140rpx;
  height: 140rpx;
  border-radius: 999rpx;
  background: #f4f6ea;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 14rpx 40rpx rgba(0, 0, 0, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.mic-btn::after {
  border: none;
}

.mic-glyph {
  font-size: 56rpx;
  line-height: 1;
}

.input-float {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
  z-index: 20;
  background: linear-gradient(to top, rgba(238, 241, 227, 0.92), rgba(238, 241, 227, 0));
}

.input-float-inner {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.input-row {
  width: 100%;
}

.actions-row {
  width: 100%;
  display: flex;
  gap: 12rpx;
}

.float-input {
  width: 100%;
  height: 88rpx;
  background: #f7f9fc;
  border-radius: 999rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  color: #2a3138;
}

.float-send {
  flex: 1;
  height: 76rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #e8b848;
  color: #fff;
  font-size: 28rpx;
  line-height: 76rpx;
}

.float-send::after {
  border: none;
}

.float-send:disabled {
  opacity: 0.45;
}

.float-close {
  flex: 1;
  height: 76rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #e9efe1;
  color: #6b7b52;
  font-size: 26rpx;
  line-height: 76rpx;
}

.float-close::after {
  border: none;
}

.bottom-area {
  padding: 22rpx 0 40rpx;
}

.scene-selector {
  background: #f4f6ea;
  border-radius: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  padding: 26rpx;
}

.selector-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #6b7b52;
  margin-bottom: 20rpx;
  display: block;
}

.scene-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.scene-option {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  padding: 22rpx 16rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.scene-option.active {
  background: #f8e8c0;
  border-color: #e8b848;
}

.option-text {
  font-size: 24rpx;
  color: #5c6570;
}

.scene-option.active .option-text {
  color: #506840;
  font-weight: 600;
}

.action-area {
  display: flex;
  justify-content: center;
  margin-top: 18rpx;
}

.end-btn {
  width: 100%;
  background: #587838;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  padding: 26rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 10rpx 26rpx rgba(88, 120, 56, 0.24);
}

.end-btn::after {
  border: none;
}

.end-btn:active {
  opacity: 0.92;
}
