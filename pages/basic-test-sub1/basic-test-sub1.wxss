/* 全局页面容器（动态顶部内边距避开导航栏） */
.page-container {
  width: 100%;
  min-height: 100vh;
  background: var(--yh-bg, #F8F8F8);
  padding: 0 30rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 40rpx);
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* 返回按钮样式 - 统一美观设计 */
.back-button {
  position: absolute;
  top: calc(var(--nav-bar-height) + 20rpx);
  left: 30rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: var(--yh-surface, #F0F0E0);
  border-radius: 40rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
  z-index: 100;
  transition: all 0.3s ease;
}

.back-button:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.back-icon-wrapper {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yh-primary, #587838);
  border-radius: 50%;
}

.back-arrow {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  color: var(--yh-text, #506840);
  font-weight: 600;
}

/* 页面标题区域 */
.page-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-top: 80rpx;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 40rpx;
  color: var(--yh-text, #506840);
  font-weight: 700;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--yh-text-muted, #88A870);
}

/* 测试卡片样式 */
.test-card {
  background-color: var(--yh-surface, #F0F0E0);
  border-radius: 24rpx;
  border: 1rpx solid var(--yh-border, #E0E0E0);
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  box-shadow: var(--yh-shadow-soft, 0 6rpx 28rpx rgba(42, 49, 56, 0.06));
  transition: all 0.3s ease;
}

.test-card:active {
  transform: translateY(4rpx);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.test-title {
  font-size: 36rpx;
  color: var(--yh-text, #506840);
  font-weight: 700;
}

.test-subtitle {
  font-size: 28rpx;
  color: var(--yh-text-secondary, #5C6F53);
  margin-bottom: 10rpx;
}

.start-btn {
  background: var(--yh-primary, #587838);
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 24rpx 60rpx;
  border: none;
  font-weight: 600;
  box-shadow: var(--yh-shadow-soft, 0 6rpx 24rpx rgba(88, 120, 56, 0.22));
  transition: all 0.3s ease;
}

.start-btn::after {
  border: none;
}

.start-btn:active {
  transform: scale(0.98);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 14rpx rgba(88, 120, 56, 0.18));
}
