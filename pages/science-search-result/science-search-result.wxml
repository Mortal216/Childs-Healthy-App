<!-- 科普搜索结果页面 -->
<view class="container" style="padding-top: {{navBarTotalHeight}}px;">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <text class="icon-search">🔍</text>
      <text class="keyword">{{keyword}}</text>
    </view>
    <text class="btn-back" bindtap="goBack">返回</text>
  </view>

  <!-- 搜索结果 -->
  <view class="result-container">
    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading-container">
      <view class="loading"></view>
      <text class="loading-text">搜索中...</text>
    </view>

    <!-- 无结果 -->
    <view wx:elif="{{!loading && articles.length === 0}}" class="empty-container">
      <text class="empty-icon">📭</text>
      <text class="empty-text">未找到相关文章</text>
      <text class="empty-subtext">换个关键词试试吧</text>
    </view>

    <!-- 搜索结果列表 -->
    <view wx:else class="article-list">
      <view wx:for="{{articles}}" wx:key="{{item.id}}" class="article-item" bindtap="viewArticleDetail" data-id="{{item.id}}">
        <view class="article-info">
          <text class="article-title">{{item.title}}</text>
          <view class="article-meta">
            <text class="article-source">{{item.source}}</text>
            <text class="article-time">{{item.publishTime}}</text>
          </view>
          <text class="article-summary">{{item.summary}}</text>
        </view>
        <view class="article-image" wx:if="{{item.image}}">
          <image src="{{item.image}}" mode="aspectFill"></image>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMoreArticles">
        <text class="load-more-text">加载更多</text>
      </view>

      <!-- 没有更多 -->
      <view wx:else class="no-more">
        <text class="no-more-text">没有更多内容了</text>
      </view>
    </view>
  </view>
</view>
