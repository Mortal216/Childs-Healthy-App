/* 科普搜索结果页面样式 */
.container {
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #e8e8e8;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: 88rpx;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: var(--yh-surface-muted, #f7f8fb);
  border-radius: 44rpx;
  padding: 0 32rpx;
  height: 64rpx;
  margin-right: 24rpx;
}

.icon-search {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #999;
}

.keyword {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.btn-back {
  font-size: 28rpx;
  color: #007aff;
  padding: 0 16rpx;
}

/* 结果容器 */
.result-container {
  padding: 120rpx 32rpx 32rpx;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading {
  width: 64rpx;
  height: 64rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #007aff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 32rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 无结果 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 128rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
}

/* 文章列表 */
.article-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.article-item {
  display: flex;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  cursor: pointer;
  transition: background-color 0.2s;
}

.article-item:hover {
  background-color: #f9f9f9;
}

.article-info {
  flex: 1;
  margin-right: 24rpx;
}

.article-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 44rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.article-source {
  font-size: 24rpx;
  color: #007aff;
  margin-right: 24rpx;
}

.article-time {
  font-size: 24rpx;
  color: #999;
}

.article-summary {
  font-size: 28rpx;
  color: #666;
  line-height: 40rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-image {
  width: 200rpx;
  height: 140rpx;
  border-radius: 8rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.article-image image {
  width: 100%;
  height: 100%;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.load-more-text {
  font-size: 28rpx;
  color: #007aff;
}

/* 没有更多 */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.no-more-text {
  font-size: 28rpx;
  color: #999;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .article-title {
    font-size: 30rpx;
  }
  
  .article-summary {
    font-size: 26rpx;
  }
  
  .article-image {
    width: 160rpx;
    height: 120rpx;
  }
}
