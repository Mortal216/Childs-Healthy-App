.page-container {
  min-height: 100vh;
  background: var(--yh-bg, #F8F8F8);
  padding-top: calc(var(--nav-bar-height) + 20rpx);
  padding-bottom: 48rpx;
}

.back-button {
  position: fixed;
  top: calc(var(--nav-bar-height) + 20rpx);
  left: 30rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 100;
  background: var(--yh-surface, #F0F0E0);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.back-icon-wrapper {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yh-primary, #587838);
  border-radius: 50%;
}

.back-arrow {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1;
  font-weight: 700;
}

.back-text {
  font-size: 28rpx;
  color: var(--yh-text, #506840);
  font-weight: 600;
}

.page-header {
  padding: 36rpx 30rpx 28rpx;
  margin-top: 72rpx;
}

.main-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--yh-text, #506840);
  display: block;
  margin-bottom: 20rpx;
}

.header-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.meta-chip {
  font-size: 24rpx;
  color: #FFFFFF;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: var(--yh-accent-purple, #C8C8E8);
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.intro-card,
.section-card,
.submit-section {
  background: var(--yh-surface, #F0F0E0);
  margin: 0 30rpx 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.intro-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.intro-title {
  font-size: 30rpx;
  color: var(--yh-text, #506840);
  font-weight: 600;
}

.help-trigger {
  font-size: 24rpx;
  color: var(--yh-text, #506840);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: var(--yh-sage, #E8B848);
  font-weight: 600;
}

.intro-text {
  font-size: 26rpx;
  color: var(--yh-text-secondary, #5C6F53);
  line-height: 1.7;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  color: var(--yh-text, #506840);
  font-weight: 600;
  margin-bottom: 10rpx;
}

.section-desc {
  font-size: 24rpx;
  color: var(--yh-text-muted, #88A870);
  line-height: 1.6;
}

.question-item + .question-item {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--yh-border, #E0E0E0);
}

.question-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.question-number {
  width: 44rpx;
  height: 44rpx;
  background: var(--yh-accent-purple, #C8C8E8);
  border-radius: 50%;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.question-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--yh-text, #506840);
  line-height: 1.55;
  font-weight: 500;
}

.option-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 14rpx;
  background: var(--yh-surface-muted, #F8F8F0);
  border: 2rpx solid transparent;
}

.option-item.selected {
  background: rgba(232, 184, 72, 0.35);
  border-color: var(--yh-sage, #E8B848);
}

.radio {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 2rpx solid var(--yh-border, #E0E0E0);
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.radio.checked {
  border-color: var(--yh-primary, #587838);
}

.radio-inner {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--yh-primary, #587838);
}

.option-text {
  flex: 1;
  font-size: 27rpx;
  color: var(--yh-text, #506840);
  line-height: 1.5;
}

.submit-btn {
  background: var(--yh-primary, #587838);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  box-shadow: var(--yh-shadow-soft, 0 8rpx 24rpx rgba(88, 120, 56, 0.22));
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: var(--yh-border, #E0E0E0);
  color: var(--yh-text-muted, #88A870);
  box-shadow: none;
}

.submit-tip {
  display: block;
  text-align: center;
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--yh-text-muted, #88A870);
}

.bottom-space {
  height: 40rpx;
}
