.page-container {
  min-height: 100vh;
  background: var(--yh-bg, #eceff4);
  padding: 0 32rpx 48rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 16rpx);
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.back-btn,
.placeholder {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yh-surface, #fff);
  border-radius: 50%;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.back-icon {
  font-size: 30rpx;
  color: var(--yh-primary, #4a7eb8);
}

.nav-title {
  font-size: 32rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
}

.cover {
  width: 100%;
  height: 360rpx;
  border-radius: var(--yh-radius-lg, 28rpx);
  background: var(--yh-surface-muted, #f7f9fc);
  margin-bottom: 28rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
}

.title {
  font-size: 38rpx;
  line-height: 1.4;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
  margin-bottom: 12rpx;
}

.author {
  font-size: 24rpx;
  color: var(--yh-text-muted, #8b939e);
  margin-bottom: 28rpx;
}

.content {
  background: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  padding: 32rpx 28rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.content text {
  font-size: 28rpx;
  line-height: 1.85;
  color: var(--yh-text-secondary, #5c6570);
  white-space: pre-wrap;
}

.empty {
  text-align: center;
  margin-top: 120rpx;
  padding: 48rpx 32rpx;
  color: var(--yh-text-muted, #8b939e);
  font-size: 28rpx;
  background: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
}
