.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0 32rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 16rpx);
  padding-bottom: 120rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-pill, 999rpx);
  padding: 12rpx 24rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--yh-text, #2a3138);
}

.search-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 黄色加深：使用主黄 */
  background: var(--yh-sage, #E8B848);
  border-radius: 50%;
}

.search-icon {
  font-size: 28rpx;
  color: var(--yh-primary, #4a7eb8);
}

.tab-nav {
  display: flex;
  background: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-md, 20rpx);
  padding: 8rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: var(--yh-text-secondary, #5c6570);
  padding: 18rpx 0;
  position: relative;
  z-index: 1;
  border-radius: var(--yh-radius-sm, 12rpx);
}

.tab-item.active {
  color: var(--yh-text, #506840);
  font-weight: 600;
  /* 黄色加深：使用主黄 */
  background: var(--yh-sage, #E8B848);
}

.tab-item.active::after {
  display: none;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.recommend-card {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.recommend-card:active {
  opacity: 0.96;
}

.card-cover {
  width: 128rpx;
  height: 128rpx;
  background-color: var(--yh-surface-muted, #f7f9fc);
  border-radius: var(--yh-radius-md, 20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.cover-placeholder {
  font-size: 44rpx;
  color: var(--yh-text-muted, #8b939e);
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
  line-height: 1.4;
}

.card-desc {
  font-size: 24rpx;
  color: var(--yh-text-secondary, #5c6570);
  line-height: 1.5;
}

.hot-card {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
}

.hot-icon {
  width: 64rpx;
  height: 64rpx;
  background-color: var(--yh-primary-soft, #e8f0f8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--yh-primary, #4a7eb8);
}

.hot-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hot-title {
  font-size: 28rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 500;
  line-height: 1.4;
}

.hot-meta {
  font-size: 24rpx;
  color: var(--yh-text-muted, #8b939e);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid var(--yh-divider, #eef1f6);
  border-top: 6rpx solid var(--yh-primary, #4a7eb8);
  border-radius: 50%;
  animation: yh-spin 0.9s linear infinite;
  margin-bottom: 28rpx;
}

@keyframes yh-spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: var(--yh-text-muted, #8b939e);
}

.card-meta {
  font-size: 22rpx;
  color: var(--yh-text-muted, #8b939e);
  margin: 4rpx 0;
}

.card-cover image {
  width: 100%;
  height: 100%;
  border-radius: var(--yh-radius-md, 20rpx);
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
}
