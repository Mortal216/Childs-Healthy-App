.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0 32rpx 48rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 40rpx);
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.back-button {
  position: absolute;
  top: calc(var(--nav-bar-height) + 16rpx);
  left: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  z-index: 100;
  background: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-pill, 999rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.back-icon {
  font-size: 28rpx;
  color: var(--yh-primary, #4a7eb8);
}

.back-text {
  font-size: 26rpx;
  color: var(--yh-text-secondary, #5c6570);
}

.page-title {
  align-self: center;
  margin-bottom: 8rpx;
  margin-top: 56rpx;
  text-align: center;
  padding: 0 24rpx;
}

.page-title text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
  display: block;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: var(--yh-text-secondary, #5c6570);
  font-weight: normal !important;
  line-height: 1.5;
}

.header-tip {
  background-color: var(--yh-warn-bg, #faf6f0);
  border: 1rpx solid var(--yh-warn-border, #eadfd2);
  border-radius: var(--yh-radius-md, 20rpx);
  padding: 22rpx 24rpx;
  margin-bottom: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: var(--yh-warn-text, #6b5348);
  line-height: 1.55;
}

.story-section {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
  margin-bottom: 24rpx;
  display: block;
}

.story-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.story-item {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.story-item:active {
  opacity: 0.96;
}

.story-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: var(--yh-radius-md, 20rpx);
  overflow: hidden;
  flex-shrink: 0;
  border: 1rpx solid var(--yh-border, #e4e9f0);
}

.story-cover image {
  width: 100%;
  height: 100%;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
}

.story-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.story-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
  margin-bottom: 8rpx;
  line-height: 1.35;
}

.story-author {
  font-size: 24rpx;
  color: var(--yh-text-secondary, #5c6570);
  margin-bottom: 6rpx;
}

.story-length {
  font-size: 22rpx;
  color: var(--yh-text-muted, #8b939e);
  margin-bottom: 12rpx;
}

.story-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  /* 跳色增强：标签默认为浅黄 */
  background-color: var(--yh-sage-soft, #F8E8C0);
  color: var(--yh-text, #506840);
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: var(--yh-radius-pill, 999rpx);
  font-weight: 500;
}

/* 交错跳色：每第 3 个标签用浅紫 */
.tag:nth-child(3n) {
  background-color: var(--yh-accent-purple, #C8C8E8);
}

.interaction-tips {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--yh-text, #2a3138);
  margin-bottom: 20rpx;
  display: block;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tip-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.tip-number {
  width: 40rpx;
  height: 40rpx;
  /* 跳色：编号圆点用浅紫 */
  background: var(--ref-lavender-200, #C8C8E8);
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.tip-content {
  flex: 1;
  font-size: 26rpx;
  color: var(--yh-text-secondary, #5c6570);
  line-height: 1.55;
}
