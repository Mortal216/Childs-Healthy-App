/* 页面容器 */
.page-container {
  min-height: 100vh;
  background: var(--yh-bg, #F8F8F8);
  padding-top: calc(var(--nav-bar-height) + 20rpx);
  padding-bottom: 40rpx;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: var(--yh-bg, #F8F8F8);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--yh-border, #E0E0E0);
  border-top-color: var(--yh-primary, #587838);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--yh-text-muted, #88A870);
}

/* 返回按钮 - 统一美观设计 */
.back-button {
  position: fixed;
  top: calc(var(--nav-bar-height) + 20rpx);
  left: 30rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 100;
  background: var(--yh-surface, #F0F0E0);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  transition: all 0.3s ease;
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.back-button:active {
  transform: scale(0.95);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 14rpx rgba(42, 49, 56, 0.05));
}

.back-icon-wrapper {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--yh-primary, #587838);
  border-radius: 50%;
}

.back-arrow {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  color: var(--yh-text, #506840);
  font-weight: 600;
}

/* 页面头部 */
.page-header {
  text-align: center;
  padding: 40rpx 30rpx 30rpx;
  margin-top: 80rpx;
}

.main-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--yh-text, #506840);
  display: block;
  margin-bottom: 16rpx;
}

.age-range {
  font-size: 26rpx;
  color: #FFFFFF;
  background: var(--yh-accent-purple, #C8C8E8);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

/* 部分切换标签 */
.section-tabs {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 30rpx;
  background: var(--yh-surface, #F0F0E0);
  margin: 0 30rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.section-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  position: relative;
  cursor: pointer;
}

.tab-text {
  font-size: 28rpx;
  color: var(--yh-text-muted, #88A870);
  font-weight: 500;
  transition: all 0.3s;
}

.section-tab.active .tab-text {
  color: var(--yh-sage, #E8B848);
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 40rpx;
  height: 4rpx;
  background: var(--yh-sage, #E8B848);
  border-radius: 2rpx;
}

/* 部分头部 */
.section-header {
  background: var(--yh-surface, #F0F0E0);
  margin: 0 30rpx 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--yh-text, #506840);
  display: block;
  margin-bottom: 12rpx;
}

.section-subtitle {
  font-size: 26rpx;
  color: var(--yh-text-secondary, #5C6F53);
  display: block;
  margin-bottom: 24rpx;
}

/* 进度信息 */
.progress-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-text {
  font-size: 24rpx;
  color: var(--yh-text-muted, #88A870);
  white-space: nowrap;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: var(--yh-primary-soft, #B8D078);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--yh-primary, #587838);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 题目列表 */
.question-list {
  padding: 0 30rpx;
}

.question-item {
  background: var(--yh-surface, #F0F0E0);
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 18rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.question-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.question-number {
  width: 44rpx;
  height: 44rpx;
  background: var(--yh-accent-purple, #C8C8E8);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.question-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--yh-text, #506840);
  line-height: 1.5;
  font-weight: 500;
}

/* 选项组 */
.option-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--yh-surface-muted, #F8F8F0);
  border-radius: 12rpx;
  border: 2rpx solid var(--yh-border, #E0E0E0);
  transition: all 0.3s;
  flex: 1;
  min-width: 160rpx;
}

.option-item.selected {
  background: var(--yh-sage, #E8B848);
  border-color: var(--yh-sage, #E8B848);
}

.radio {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid var(--yh-border, #E0E0E0);
  border-radius: 50%;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.radio.checked {
  border-color: var(--yh-primary, #587838);
  background: var(--yh-primary, #587838);
}

.radio-inner {
  width: 16rpx;
  height: 16rpx;
  background: #FFFFFF;
  border-radius: 50%;
}

.option-text {
  font-size: 28rpx;
  color: var(--yh-text-secondary, #5C6F53);
  font-weight: 500;
}

.option-item.selected .option-text {
  color: #FFFFFF;
}

/* 底部按钮组 */
.button-group {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  gap: 20rpx;
  margin-top: 20rpx;
}

.nav-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s;
}

.prev-btn {
  background: var(--yh-surface, #F0F0E0);
  color: var(--yh-text, #506840);
  border: 2rpx solid var(--yh-accent-purple, #C8C8E8);
  box-sizing: border-box;
}

.prev-btn.disabled {
  opacity: 0.5;
}

.next-btn {
  background: var(--yh-primary, #587838);
  color: #FFFFFF;
  box-shadow: var(--yh-shadow-soft, 0 6rpx 20rpx rgba(88, 120, 56, 0.22));
}

.next-btn:active {
  transform: scale(0.98);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 14rpx rgba(88, 120, 56, 0.18));
}

/* 底部间距 */
.bottom-space {
  height: 40rpx;
}

/* ========== 横向单选表格样式（乙部分和丁部分） ========== */

/* 表头 */
.table-header {
  display: flex;
  align-items: center;
  background: var(--yh-surface, #F0F0E0);
  padding: 24rpx 30rpx;
  margin: 0 30rpx 16rpx;
  border-radius: 16rpx;
  border-bottom: 2rpx solid var(--yh-border, #E0E0E0);
}

.header-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--yh-text, #506840);
  font-weight: 500;
}

.header-options {
  display: flex;
  gap: 60rpx;
}

.header-option {
  width: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--yh-text-muted, #88A870);
  font-weight: 500;
}

/* 题目行 */
.question-row {
  display: flex;
  align-items: center;
  background: var(--yh-surface, #F0F0E0);
  padding: 24rpx 30rpx;
  margin: 0 30rpx 12rpx;
  border-radius: 16rpx;
  box-shadow: var(--yh-shadow-soft, 0 4rpx 18rpx rgba(42, 49, 56, 0.05));
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

.row-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--yh-text, #506840);
  line-height: 1.4;
  padding-right: 20rpx;
}

.row-options {
  display: flex;
  gap: 60rpx;
}

.radio-cell {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.radio-circle {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid var(--yh-border, #E0E0E0);
  border-radius: 50%;
  transition: all 0.3s;
  background: var(--yh-bg-elevated, #FFFFFF);
}

.radio-circle.checked {
  border-color: var(--yh-primary, #587838);
  background: var(--yh-primary, #587838);
  box-shadow: 0 0 0 4rpx rgba(88, 120, 56, 0.18);
}

/* 响应式适配 */
@media screen and (max-width: 375px) {
  .main-title {
    font-size: 36rpx;
  }
  
  .section-title {
    font-size: 30rpx;
  }
  
  .question-text {
    font-size: 28rpx;
  }
  
  .option-item {
    min-width: 140rpx;
    padding: 16rpx 20rpx;
  }
}

/* 提交成功弹窗 - 右侧 */
.success-popup {
  position: fixed;
  top: 0;
  right: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: flex-end;
  z-index: 9999;
}

.success-content {
  width: 80%;
  max-width: 400rpx;
  background: var(--yh-surface, #F0F0E0);
  border-radius: 24rpx 0 0 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  box-shadow: -8rpx 0 32rpx rgba(42, 49, 56, 0.12);
  animation: slideInRight 0.3s ease-out;
  border: 1rpx solid var(--yh-border, #E0E0E0);
}

@keyframes slideInRight {
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(0);
  }
}

.success-icon {
  width: 100rpx;
  height: 100rpx;
  background: var(--yh-primary, #587838);
  color: #FFFFFF;
  font-size: 60rpx;
  font-weight: bold;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--yh-text, #506840);
}

.success-desc {
  font-size: 28rpx;
  color: var(--yh-text-secondary, #5C6F53);
  text-align: center;
  line-height: 1.5;
}
