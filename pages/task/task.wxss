.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0 32rpx 48rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 20rpx);
  padding-bottom: 60rpx;
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: var(--yh-surface, #fff);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.back-icon {
  font-size: 30rpx;
  color: var(--yh-primary, #4a7eb8);
}

.nav-title {
  font-size: 32rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
}

.placeholder {
  width: 64rpx;
}

.age-selector-section {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  padding: 32rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.section-label {
  font-size: 26rpx;
  color: var(--yh-text-secondary, #5c6570);
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.age-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--yh-surface-muted, #f7f9fc);
  padding: 22rpx 28rpx;
  border-radius: var(--yh-radius-md, 20rpx);
  border: 1rpx solid var(--yh-border, #e4e9f0);
}

.age-text {
  font-size: 30rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 500;
}

.picker-arrow {
  font-size: 22rpx;
  color: var(--yh-text-muted, #8b939e);
}

.task-card {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  padding: 32rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-card, 0 8rpx 32rpx rgba(42, 49, 56, 0.07));
}

.task-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--yh-divider, #eef1f6);
}

.task-time {
  display: flex;
  align-items: center;
}

.time-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
}

.time-text {
  font-size: 24rpx;
  color: var(--yh-text-muted, #8b939e);
}

.task-category {
  background-color: var(--yh-primary-soft, #e8f0f8);
  color: var(--yh-primary-pressed, #3d6a9c);
  font-size: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: var(--yh-radius-pill, 999rpx);
  font-weight: 500;
}

.task-content {
  margin-bottom: 24rpx;
}

.task-title {
  font-size: 34rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
  margin-bottom: 12rpx;
  line-height: 1.35;
}

.task-description {
  font-size: 28rpx;
  color: var(--yh-text-secondary, #5c6570);
  line-height: 1.6;
}

.task-tips {
  background-color: var(--yh-warn-bg, #faf6f0);
  border-radius: var(--yh-radius-md, 20rpx);
  padding: 22rpx 24rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: flex-start;
  border: 1rpx solid var(--yh-warn-border, #eadfd2);
}

.tips-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 26rpx;
  color: var(--yh-warn-text, #6b5348);
  line-height: 1.55;
  flex: 1;
}

.task-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx 0;
  border-radius: var(--yh-radius-pill, 999rpx);
  font-weight: 500;
}

.complete-btn {
  background: var(--yh-primary, #587838);
  color: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(90, 146, 120, 0.28);
}

.refresh-btn {
  background-color: var(--yh-surface-muted, #f7f9fc);
  color: var(--yh-text-secondary, #5c6570);
  border: 1rpx solid var(--yh-border, #e4e9f0);
}

.btn-icon {
  font-size: 30rpx;
  margin-right: 10rpx;
}

.btn-text {
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
  opacity: 0.85;
}

.empty-text {
  font-size: 28rpx;
  color: var(--yh-text-muted, #8b939e);
}

.history-section {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  margin-bottom: 28rpx;
  overflow: hidden;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background-color: var(--yh-surface-muted, #f7f9fc);
}

.history-title {
  font-size: 28rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
}

.history-arrow {
  font-size: 22rpx;
  color: var(--yh-text-muted, #8b939e);
}

.history-list {
  padding: 0 32rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--yh-divider, #eef1f6);
}

.history-item:last-child {
  border-bottom: none;
}

.history-info {
  display: flex;
  flex-direction: column;
}

.history-title-text {
  font-size: 28rpx;
  color: var(--yh-text, #2a3138);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.history-category {
  font-size: 24rpx;
  color: var(--yh-text-muted, #8b939e);
}

.history-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.history-date {
  font-size: 22rpx;
  color: var(--yh-text-secondary, #5c6570);
  margin-bottom: 4rpx;
}

.history-age {
  font-size: 20rpx;
  color: var(--yh-text-muted, #8b939e);
}

.history-empty {
  padding: 40rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--yh-text-muted, #8b939e);
}

.tips-section {
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  padding: 28rpx 32rpx;
  border: 1rpx solid var(--yh-border, #e4e9f0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.tips-header {
  margin-bottom: 16rpx;
}

.tips-title {
  font-size: 28rpx;
  color: var(--yh-text, #2a3138);
  font-weight: 600;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tips-item {
  font-size: 26rpx;
  color: var(--yh-text-secondary, #5c6570);
  line-height: 1.55;
}
