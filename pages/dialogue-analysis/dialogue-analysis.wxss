page {
  background-color: var(--yh-bg, #eceff4);
}

.status-bar {
  background: var(--yh-surface, #fff) !important;
  border-bottom: 1rpx solid var(--yh-border, #dde3eb) !important;
}

.content {
  padding: 32rpx !important;
  padding-bottom: 160rpx !important;
}

.instruction {
  font-size: 28rpx;
  color: var(--yh-text-secondary, #5a626c);
  line-height: 1.7;
  margin-bottom: 28rpx;
}

.text-input {
  width: 100%;
  height: 220rpx;
  background-color: var(--yh-surface, #fff);
  border-radius: var(--yh-radius-lg, 28rpx);
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--yh-border, #dde3eb);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 24rpx rgba(40, 48, 56, 0.045));
  font-size: 28rpx;
  color: var(--yh-text, #283038);
}

.upload-buttons {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 36rpx;
}

.upload-btn {
  flex: 1;
  background-color: var(--yh-surface, #fff);
  border: 2rpx solid var(--yh-primary-faint, #cddfea);
  color: var(--yh-primary, #4a7eb8);
  border-radius: var(--yh-radius-pill, 999rpx);
  font-size: 24rpx;
  margin: 0;
  padding: 16rpx 8rpx;
  font-weight: 500;
}

.upload-btn::after {
  border: none;
}

.analyze-btn {
  background: var(--yh-primary, #587838);
  color: #fff;
  border-radius: var(--yh-radius-pill, 999rpx);
  margin-bottom: 28rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(74, 126, 184, 0.22);
}

.analyze-btn::after {
  border: none;
}

.cancel {
  text-align: center;
  color: var(--yh-text-muted, #8b929c);
  font-size: 28rpx;
}