.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0 30rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 20rpx);
  padding-bottom: 120rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: var(--yh-surface, #F0F0E0);
  border-radius: var(--yh-radius-pill, 999rpx);
  padding: 12rpx 24rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--yh-border, #E0E0E0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--yh-text, #506840);
}

.search-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-icon {
  font-size: 28rpx;
  color: var(--yh-primary, #587838);
}

.tab-nav {
  display: flex;
  background: var(--yh-surface, #F0F0E0);
  border-radius: var(--yh-radius-md, 20rpx);
  padding: 8rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--yh-border, #E0E0E0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: var(--yh-text-secondary, #587048);
  padding: 18rpx 0;
  position: relative;
  border-radius: var(--yh-radius-sm, 12rpx);
}

.tab-item.active {
  color: var(--yh-text, #506840);
  font-weight: 600;
  /* 黄色加深：使用主黄 */
  background: var(--yh-sage, #E8B848);
}

.tab-item.active::after {
  display: none;
}

.topic-tags {
  display: flex;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.topic-tag {
  padding: 8rpx 15rpx;
  /* 话题标签更“正黄” */
  background-color: var(--yh-sage, #E8B848);
  border-radius: 15rpx;
  font-size: 24rpx;
  color: #FFFFFF;
}

.topic-tag:nth-child(2n) {
  background-color: var(--yh-accent-purple, #C8C8E8);
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.post-card {
  background-color: var(--yh-surface, #F0F0E0);
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid var(--yh-border, #E0E0E0);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 20rpx rgba(42, 49, 56, 0.05));
}

.post-header {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  background-color: var(--yh-surface-muted, #F8F8F0);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder {
  font-size: 24rpx;
  color: var(--yh-text-secondary, #587048);
}

.post-meta {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.post-author {
  font-size: 28rpx;
  color: var(--yh-text, #506840);
  font-weight: 500;
}

.post-time {
  font-size: 24rpx;
  color: var(--yh-text-muted, #88A870);
}

.post-content {
  margin-bottom: 15rpx;
}

.post-text {
  font-size: 26rpx;
  color: var(--yh-text, #506840);
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.post-images {
  display: flex;
  gap: 15rpx;
}

.image-placeholder {
  width: 120rpx;
  height: 120rpx;
  background-color: var(--yh-surface-muted, #F8F8F0);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--yh-text-muted, #88A870);
}

.post-actions {
  display: flex;
  gap: 30rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--yh-text-secondary, #587048);
}

.action-icon {
  font-size: 24rpx;
}

.action-count {
  font-size: 24rpx;
}

/* 底部导航栏 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--ref-green-150, #B8D078);
  border-top: 1rpx solid var(--yh-border, #E0E0E0);
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 15rpx 0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 15rpx 20rpx;
  cursor: pointer;
}

.nav-item.active {
  color: var(--yh-primary, #587838);
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
}

.nav-text {
  font-size: 22rpx;
  color: var(--yh-text-secondary, #587048);
}

.nav-item.active .nav-text {
  color: var(--yh-primary, #587838);
}

/* 创作按钮 */
.create-btn-container {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.create-btn {
  display: flex;
  align-items: center;
  background-color: var(--yh-sage, #E8B848);
  padding: 16rpx 32rpx;
  border-radius: var(--yh-radius-pill, 999rpx);
  gap: 10rpx;
  border: 1rpx solid var(--yh-yellow-500, #E0B848);
}

.create-icon {
  font-size: 28rpx;
}

.create-text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 创作弹窗 */
.create-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.create-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
}

.create-container {
  position: relative;
  width: 85%;
  max-height: 80vh;
  background-color: var(--yh-surface, #F0F0E0);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  z-index: 1001;
}

.create-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--yh-border, #E0E0E0);
}

.create-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--yh-text, #506840);
}

.create-close {
  font-size: 40rpx;
  color: var(--yh-text-muted, #88A870);
  padding: 0 10rpx;
}

.create-content {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.create-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid var(--yh-border, #E0E0E0);
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  resize: none;
}

.create-tags {
  margin-top: 20rpx;
}

.create-tag-label {
  font-size: 26rpx;
  color: var(--yh-text-secondary, #587048);
  margin-bottom: 15rpx;
  display: block;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.tag-item {
  padding: 10rpx 20rpx;
  border: 1rpx solid var(--yh-border, #E0E0E0);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--yh-text-secondary, #587048);
  background-color: var(--yh-surface, #F0F0E0);
}

.tag-item.active {
  border-color: var(--yh-primary-faint, #cddfea);
  background-color: var(--yh-primary-soft, #e4edf6);
  color: var(--yh-primary-pressed, #3d6a9c);
}

.create-footer {
  padding: 20rpx 30rpx 40rpx;
  border-top: 1rpx solid var(--yh-border, #E0E0E0);
}

.create-submit {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 30rpx;
  border: none;
  background-color: var(--yh-sage, #E8B848);
  color: #FFFFFF;
}

.create-submit::after {
  border: none;
}

.create-submit.active {
  background: var(--yh-primary, #587838);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(74, 126, 184, 0.22);
}

/* 空提示 */
.empty-tip {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--yh-text-muted, #88A870);
}