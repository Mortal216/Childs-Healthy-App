/* 样式与 step1 基本一致，复用即可 */
.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0;
  box-sizing: border-box;
  padding-top: var(--navBarHeight);
}

.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--yh-surface, #fff);
  padding: 22rpx 28rpx;
  margin: 0 24rpx 16rpx;
  border-radius: var(--yh-radius-lg, 28rpx);
  border: 1rpx solid var(--yh-border, #dde3eb);
  box-shadow: var(--yh-shadow-soft, 0 4rpx 24rpx rgba(40, 48, 56, 0.045));
}

.back-btn, .help-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon, .help-icon {
  font-size: 32rpx;
  color: #333;
}

.nav-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.progress-bar {
  width: 100%;
  height: 4rpx;
  background-color: #E5E5E5;
}

.progress {
  height: 100%;
  background-color: var(--yh-primary, #587838);
}

.step-title {
  font-size: 26rpx;
  color: #666;
  margin: 30rpx 30rpx;
}

.form {
  padding: 0 30rpx;
}

.input-item {
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background-color: var(--yh-surface, #fff);
  border: 1rpx solid var(--yh-border, #dde3eb);
  border-radius: var(--yh-radius-lg, 28rpx);
  padding: 0 30rpx;
  font-size: 28rpx;
  color: var(--yh-text, #283038);
  box-sizing: border-box;
}

.submit-btn {
  width: 60%;
  height: 88rpx;
  background: var(--yh-primary, #587838);
  color: #fff;
  border-radius: var(--yh-radius-pill, 999rpx);
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: block;
  margin: 40rpx auto 0;
  box-shadow: 0 8rpx 24rpx rgba(74, 126, 184, 0.22);
}

.footer-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin-top: 80rpx;
}