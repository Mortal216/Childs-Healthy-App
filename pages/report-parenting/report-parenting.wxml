<!-- 抚养方式测评报告页面 -->
<view class="container" style="padding-top: {{navBarTotalHeight}}px;">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <image src="../../images/tab/top-help.png" class="back-icon"></image>
    </view>
    <view class="header-center">抚养方式测评报告</view>
    <view class="header-right">
      <view class="share-btn" bindtap="shareReport">分享</view>
    </view>
  </view>

  <!-- 宝宝信息 -->
  <view class="baby-info">
    <view class="baby-avatar">
      <image src="../../images/tab/yiya-IP.png" class="avatar"></image>
    </view>
    <view class="baby-details">
      <view class="baby-name">{{babyInfo.name}}</view>
      <view class="baby-age">月龄：{{babyInfo.age}}</view>
      <view class="test-time">测评时间：{{babyInfo.testTime}}</view>
    </view>
  </view>

  <!-- 总分 -->
  <view class="score-section">
    <view class="score-title">抚养方式评分</view>
    <view class="score-circle">
      <view class="score-number">{{totalScore}}/20</view>
      <view class="score-level" style="background-color: {{scoreLevelColor}}">{{scoreLevel}}</view>
    </view>
    <view class="score-bar">
      <view class="score-progress" style="width: {{totalScore * 5}}%"></view>
    </view>
  </view>

  <!-- 各维度得分 -->
  <view class="dimension-section">
    <view class="section-title">各维度分析</view>
    <view class="dimension-list">
      <view class="dimension-item" wx:for="{{dimensionScores}}" wx:key="{{index}}">
        <view class="dimension-name">{{item.dimension}}</view>
        <view class="dimension-score">
          <view class="score-value">{{item.score}}/{{item.maxScore}}分</view>
          <view class="score-level-tag" style="background-color: {{item.levelColor}}">{{item.level}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 个性化干预建议 -->
  <view class="suggestion-section">
    <view class="section-title">个性化建议</view>
    <view class="suggestion-list">
      <view class="suggestion-item" wx:for="{{suggestions}}" wx:key="{{index}}">
        <view class="suggestion-icon">
          <image src="../../images/tab/top-help.png" class="icon"></image>
        </view>
        <view class="suggestion-content">{{item}}</view>
      </view>
    </view>
  </view>

  <!-- 重新测评按钮 -->
  <view class="footer">
    <view class="retry-btn" bindtap="goToTest">重新测评</view>
  </view>
</view>
