<!-- 页面容器 -->
<view class="page-container">
  <!-- 标题 -->
  <view class="title">创建账号</view>

  <!-- 手机号输入框 -->
  <view class="input-item">
    <input 
      class="input" 
      placeholder="请输入手机号" 
      bindinput="onPhoneInput" 
      value="{{phone}}"
      type="number"
    />
  </view>

  <!-- 验证码输入框（带获取按钮） -->
  <view class="input-item">
    <input 
      class="input" 
      placeholder="请输入验证码" 
      bindinput="onCodeInput" 
      value="{{code}}"
      type="number"
    />
    <button 
      class="code-btn" 
      bindtap="getCode" 
      disabled="{{codeDisabled}}"
    >
      {{codeText}}
    </button>
  </view>

  <!-- 设置密码输入框 -->
  <view class="input-item">
    <input 
      class="input" 
      placeholder="请设置6-16位密码" 
      password="{{true}}" 
      bindinput="onPwdInput" 
      value="{{pwd}}"
    />
  </view>

  <!-- 确认密码输入框 -->
  <view class="input-item">
    <input 
      class="input" 
      placeholder="请再次输入密码" 
      password="{{true}}" 
      bindinput="onPwdConfirmInput" 
      value="{{pwdConfirm}}"
    />
  </view>

  <!-- 注册按钮 -->
  <button class="register-btn" bindtap="register">注册</button>

  <!-- 已有账号跳转登录 -->
  <view class="login-link" bindtap="goToLogin">
    已有账号？<text class="link-text">立即登录</text>
  </view>

  <!-- 底部标语 -->
  <view class="footer-text">科学评估·个性化干预</view>
</view>