/* 全局页面容器 - 匹配浅黄色背景 */
.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 120rpx 60rpx 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 标题样式 */
.title {
  font-size: 48rpx;
  color: #5A8C38; /* 绿色标题 */
  font-weight: bold;
  margin-bottom: 80rpx;
}

/* 输入项容器 */
.input-item {
  width: 100%;
  margin-bottom: 30rpx;
  position: relative;
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 80rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #4a7eb8; /* 浅蓝色边框 */
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* 获取验证码按钮 */
.code-btn {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  background-color: #4a7eb8;
  color: #FFFFFF;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  border: none;
}

.code-btn[disabled] {
  background-color: #CCCCCC;
  color: #999999;
}

/* 注册按钮 */
.register-btn {
  width: 60%;
  height: 80rpx;
  background-color: #4a7eb8;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 32rpx;
  border: none;
  margin: 40rpx 0 30rpx;
}

/* 登录跳转链接 */
.login-link {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 80rpx;
}

.link-text {
  color: #4a7eb8;
}

/* 底部标语 */
.footer-text {
  font-size: 24rpx;
  color: #666666;
  margin-top: auto;
  margin-bottom: 40rpx;
}