/* 全局页面容器 - 匹配浅黄色背景 */
.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: var(--yh-bg, #eceff4);
  padding: 0 30rpx;
  box-sizing: border-box;
  padding-top: calc(var(--nav-bar-height) + 20rpx);
  padding-bottom: 120rpx; /* 适配底部tabBar */
}

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.back-btn, .help-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon, .help-icon {
  font-size: 32rpx;
  color: #333333;
}

.nav-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

/* 通用区域样式 */
.section {
  margin-bottom: 40rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

/* 发展等级容器 */
.development-level-container {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
}

.level-info {
  margin-bottom: 20rpx;
}

.level-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 10rpx;
  display: block;
}

.level-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

.radar-placeholder {
  width: 100%;
  height: 300rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #dddddd;
}

.placeholder-text {
  font-size: 24rpx;
  color: #999999;
}

/* 发展轨迹容器 */
.development-trail-container {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
}

/* 轨迹图表 */
.trail-chart {
  width: 100%;
  height: 400rpx;
}

.chart-container {
  width: 100%;
  height: 100%;
  position: relative;
}

.chart-axis {
  width: 100%;
  height: 100%;
  position: relative;
  border-bottom: 2rpx solid #333333;
  border-left: 2rpx solid #333333;
}

.x-axis {
  position: absolute;
  bottom: -30rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
}

.x-axis-label {
  font-size: 20rpx;
  color: #666666;
}

.y-axis {
  position: absolute;
  top: 0;
  left: -40rpx;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.y-axis-label {
  font-size: 20rpx;
  color: #666666;
}

.chart-line {
  width: 100%;
  height: 100%;
  position: relative;
}

.line-path {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--yh-primary-soft, #88A870);
  pointer-events: none;
}

.line-point {
  position: absolute;
  width: 30rpx;
  height: 30rpx;
  background-color: #4a7eb8;
  border-radius: 50%;
  transform: translate(-50%, 50%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.point-value {
  font-size: 16rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 空轨迹 */
.empty-trail {
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  border: 1rpx dashed #dddddd;
}

/* 空项目 */
.empty-item {
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

/* 加载状态 */
.loading-section {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 500rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #666666;
}

/* 未完成测评列表 */
.unfinished-list {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
}

.unfinished-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.unfinished-item:last-child {
  border-bottom: none;
}

.test-name {
  font-size: 28rpx;
  color: #333333;
}

.arrow {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 28rpx;
  color: #999999;
}