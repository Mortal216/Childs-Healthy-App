    {
      "id": "part2",
      "title": "第二部分 动作及手势",
      "subsections": [
        {
          "id": "A",
          "title": "A. 初期沟通手势",
          "description": "当婴儿刚开始学习沟通的时候，他们经常用手势去表达他们的思想和愿望。选出以下哪些项目可以是您孩子平时所做的动作。（“有时”指孩子用过一次以上；“经常”指需要用的时候大部分会用到）",
          "type": "multiple_choice",
          "options": ["还没有", "有时会", "经常会"],
          "items": [
            { "id": 1, "text": "举高他/她的手表示想要抱抱。" },
            { "id": 2, "text": "当有人离开时，做“再见”的手势。" },
            { "id": 3, "text": "抱拳表示“谢谢！”" },
            { "id": 4, "text": "指（包括手臂及手指一起伸展）向一些有趣的对象或事件。" },
            { "id": 5, "text": "把他手中的玩具或对象交给你。" },
            { "id": 6, "text": "“咿咿”嘴表示好吃。" },
            { "id": 7, "text": "伸展他/她的手臂，显示手中握着一些东西。" },
            { "id": 8, "text": "摇头表示“不好/不要/不想”。" },
            { "id": 9, "text": "摊开双手表示“没有”。" },
            { "id": 10, "text": "飞吻。" },
            { "id": 11, "text": "点头表示“好/同意”。" }
          ]
        },
        {
          "id": "B",
          "title": "B. 游戏和常做的事（自发或引导的均可）",
          "description": "您的孩子有没有做过以下事情？",
          "type": "multiple_choice",
          "options": ["还没有", "有"],
          "items": [
            { "id": 1, "text": "玩“猫儿”。（双手掩面，然后突然打开给人惊喜。）" },
            { "id": 2, "text": "追逐游戏。" },
            { "id": 3, "text": "唱歌。" },
            { "id": 4, "text": "跳舞。" },
            { "id": 5, "text": "虫虫飞" }
          ]
        },
        {
          "id": "C",
          "title": "C. 动作",
          "description": "您的孩子做过或尝试做以下的事情吗？",
          "type": "multiple_choice",
          "options": ["还没有", "有"],
          "items": [
            { "id": 1, "text": "把电话放在耳边。" },
            { "id": 2, "text": "扔球。" },
            { "id": 3, "text": "自己戴帽子。" },
            { "id": 4, "text": "用杯喝东西。" },
            { "id": 5, "text": "推车。" },
            { "id": 6, "text": "用梳子梳自己的头发。" },
            { "id": 7, "text": "自己穿鞋或袜。" },
            { "id": 8, "text": "用勺或叉吃东西。" },
            { "id": 9, "text": "用毛巾抹脸或手。" },
            { "id": 10, "text": "遇到烫的食物，他会用嘴吹凉。" },
            { "id": 11, "text": "用勺在杯子/碗内装作搅动。" },
            { "id": 12, "text": "闻花的香味。" },
            { "id": 13, "text": "自己戴手表/项链/手链/发卡。" },
            { "id": 14, "text": "用牙刷刷牙。" },
            { "id": 15, "text": "闭上眼装睡觉。" }
          ]
        },
        {
          "id": "D",
          "title": "D. 模仿做父母",
          "description": "这里有些动作是孩子会对毛毛动物或布娃娃做的。请指出您曾否见过您的孩子做以下的动作。",
          "type": "multiple_choice",
          "options": ["还没有", "有"],
          "items": [
            { "id": 1, "text": "用奶瓶、杯子或勺喂。" },
            { "id": 2, "text": "吻它或拥抱它。" },
            { "id": 3, "text": "拍睡觉。" },
            { "id": 4, "text": "抱娃娃轻摇。" },
            { "id": 5, "text": "跟它说话/叨叨。" }
          ]
        },
        {
          "id": "E",
          "title": "E. 模仿成人的动作（无论用真的对象或玩具）",
          "description": "您的孩子有没有做或尝试做以下的动作？",
          "type": "multiple_choice",
          "options": ["还没有", "有"],
          "items": [
            { "id": 1, "text": "“看书”（拿起书一页一页地翻）。" },
            { "id": 2, "text": "用BB机/手机/遥控器。" },
            { "id": 3, "text": "用笔画。" },
            { "id": 4, "text": "用抹布擦桌。" },
            { "id": 5, "text": "戴眼镜。" },
            { "id": 6, "text": "用钥匙开门。" },
            { "id": 7, "text": "用扫把扫地。" }
          ]
        }
      ]
    }
